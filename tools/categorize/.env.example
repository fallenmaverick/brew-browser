# Copy this file to .env and fill in your API key.
# .env is gitignored — never commits.
#
# Pick ONE provider. Script auto-detects which one is set.
# If both are set, ANTHROPIC takes precedence.

# OpenAI (default: gpt-4o-mini — cheap + fast, ~$1 for full bulk run)
# OPENAI_API_KEY=sk-...

# Anthropic (default: claude-haiku-4-5 — slightly better at nuanced classification)
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides
# CATEGORIZE_MODEL=gpt-4o-mini          # or claude-haiku-4-5
# CATEGORIZE_BATCH_SIZE=50              # items per LLM call
# CATEGORIZE_MAX_CATEGORIES=5           # per item
# CATEGORIZE_DRY_RUN=0                  # set to 1 to skip LLM calls (diff only)
# CATEGORIZE_LIMIT=0                    # set >0 to limit total items processed (testing)
